# PostgreSQL
DATABASE_URL=postgresql://username:password@localhost:5432/swahilipot_attendance

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# SMTP (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# Geofence (latitude, longitude, radius in meters)
GEOFENCE_LAT=0.000000
GEOFENCE_LON=0.000000
GEOFENCE_RADIUS_METERS=100

# Work start time for on-time/late classification (HH:MM)
WORK_START_TIME=09:00
